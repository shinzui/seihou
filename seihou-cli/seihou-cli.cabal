cabal-version: 3.0
name: seihou-cli
version: 0.1.0.0
synopsis: CLI for Seihou project scaffolding
build-type: Simple

executable seihou
  default-language: GHC2024
  default-extensions: OverloadedStrings
  hs-source-dirs: src
  main-is: Main.hs
  other-modules:
    Seihou.CLI.Commands
    Seihou.CLI.Init
    Seihou.CLI.Install
    Seihou.CLI.NewModule
    Seihou.CLI.Run
    Seihou.CLI.Status
    Seihou.CLI.Validate
    Seihou.CLI.Vars

  build-depends:
    base >=4.18 && <5,
    containers >=0.6 && <1,
    directory >=1.3 && <2,
    effectful-core >=2.4 && <3,
    filepath >=1.4 && <2,
    optparse-applicative >=0.18 && <1,
    process >=1.6 && <2,
    seihou-core,
    temporary >=1.3 && <2,
    text >=2.0 && <3,
    time >=1.12 && <2,
